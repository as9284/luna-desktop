    "better-sqlite3": "^12.11.1",
    "docx-preview": "^0.3.7",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "fflate": "^0.8.3",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^4.10.38",
